k3s.yaml
node-token
*.token
.kube/

# secrets / env
.env
.env.*
!.env.example
*secret*.yaml
!*secret*.example.yaml
*.pem
*.key
*.pub
id_rsa*
secrets/

# ansible
*.retry
*.vault

# python
__pycache__/
*.py[cod]

# argo / helm local
charts/*.tgz

# os / editor
.DS_Store
*.swp
.idea/
.vscode/
